---
import Session from './Session.astro';
import Proyects from './Proyects.astro';
---

<Session id="proyectos" nombre="Proyetos">
  <ul class='flex flex-col w-full p-2 px-4 rounded-md text-sm'>
    <li class='mb-3 text-gray-600 py-2 flex flex-col justify-center'>
      <Proyects
        titulo='BioDash'
        descripcion='Esta backend sirve para llevar el registro de los principales parámetros cardiovasculares y glucemia de los pacientes. Está destinada a ser utilizado por un profesional de la salud, pero podría resultarle útil a cualquier persona que necesite realizar un seguimiento de sus parámetros vitales. Actualmente estoy trabajando el frontend.'
        url='https://biodash.onrender.com/'
        repo_url='https://github.com/markospy/biodash'
        imagen='imagenes/biodash.png'
        techs={['FastApi', 'MySql', 'SqlAlchemy', 'React']}
      />
    </li>
    <li class='mb-3 text-gray-600 py-2 flex flex-col justify-center'>
      <Proyects
        titulo='Bet Master'
        descripcion='Landing page que hice para un cliente. Muestra el historial de profits de un hipster de apuestas deportivas.'
        url='https://www.master-pro.net/'
        imagen='imagenes/bet_master.png'
        techs={['HTML5', 'CSS3', 'Tailwind', 'Astro']}
      />
    </li>
  </ul>
</Session>